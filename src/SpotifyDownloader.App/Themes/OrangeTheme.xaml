<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SystemAccentColor">#F39C12</Color>
    <Color x:Key="SystemAccentColorDark1">#D68910</Color>
    <Color x:Key="SystemAccentColorDark2">#B9770E</Color>
    <Color x:Key="SystemAccentColorLight1">#F5B041</Color>
    <Color x:Key="SystemAccentColorLight2">#F8C471</Color>
    <SolidColorBrush x:Key="AccentButtonBackground" Color="#F39C12"/>
    <SolidColorBrush x:Key="AccentButtonForeground" Color="White"/>
    <SolidColorBrush x:Key="PageBackground" Color="#121212"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#F39C12"/>
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#F39C12"/>
    <x:Double x:Key="ControlCornerRadius">8</x:Double>
    <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
</ResourceDictionary>
