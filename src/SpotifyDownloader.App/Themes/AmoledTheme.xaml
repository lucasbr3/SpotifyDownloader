<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SystemAccentColor">#1DB954</Color>
    <Color x:Key="SystemAccentColorDark1">#17A34A</Color>
    <Color x:Key="SystemAccentColorDark2">#128F3F</Color>
    <Color x:Key="SystemAccentColorLight1">#4ACC7A</Color>
    <Color x:Key="SystemAccentColorLight2">#7ADB9E</Color>

    <SolidColorBrush x:Key="AccentButtonBackground" Color="#1DB954"/>
    <SolidColorBrush x:Key="AccentButtonForeground" Color="White"/>
    <SolidColorBrush x:Key="PageBackground" Color="#000000"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#111111"/>
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#111111"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#B3B3B3"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#111111"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#1DB954"/>
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#1DB954"/>
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#1DB954"/>
    <x:Double x:Key="ControlCornerRadius">8</x:Double>
    <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
</ResourceDictionary>
