<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SystemAccentColor">#8B5CF6</Color>
    <Color x:Key="SystemAccentColorDark1">#7C3AED</Color>
    <Color x:Key="SystemAccentColorDark2">#6D28D9</Color>
    <Color x:Key="SystemAccentColorLight1">#A78BFA</Color>
    <Color x:Key="SystemAccentColorLight2">#C4B5FD</Color>
    <SolidColorBrush x:Key="AccentButtonBackground" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="AccentButtonForeground" Color="White"/>
    <SolidColorBrush x:Key="PageBackground" Color="#121212"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#8B5CF6"/>
    <x:Double x:Key="ControlCornerRadius">8</x:Double>
    <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
</ResourceDictionary>
