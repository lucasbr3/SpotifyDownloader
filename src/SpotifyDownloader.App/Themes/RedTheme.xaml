<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SystemAccentColor">#E74C3C</Color>
    <Color x:Key="SystemAccentColorDark1">#C0392B</Color>
    <Color x:Key="SystemAccentColorDark2">#A93226</Color>
    <Color x:Key="SystemAccentColorLight1">#EC7063</Color>
    <Color x:Key="SystemAccentColorLight2">#F1948A</Color>
    <SolidColorBrush x:Key="AccentButtonBackground" Color="#E74C3C"/>
    <SolidColorBrush x:Key="AccentButtonForeground" Color="White"/>
    <SolidColorBrush x:Key="PageBackground" Color="#121212"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#E74C3C"/>
    <x:Double x:Key="ControlCornerRadius">8</x:Double>
    <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
</ResourceDictionary>
