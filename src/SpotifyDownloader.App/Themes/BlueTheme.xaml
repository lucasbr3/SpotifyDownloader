<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SystemAccentColor">#0078D4</Color>
    <Color x:Key="SystemAccentColorDark1">#006CBE</Color>
    <Color x:Key="SystemAccentColorDark2">#005A9E</Color>
    <Color x:Key="SystemAccentColorLight1">#3399E0</Color>
    <Color x:Key="SystemAccentColorLight2">#66B2E8</Color>

    <SolidColorBrush x:Key="AccentButtonBackground" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentButtonForeground" Color="White"/>
    <SolidColorBrush x:Key="PageBackground" Color="#121212"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#B3B3B3"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#808080"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#0078D4"/>
    <x:Double x:Key="ControlCornerRadius">8</x:Double>
    <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
</ResourceDictionary>
