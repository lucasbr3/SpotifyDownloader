<muxc:Window
    x:Class="SpotifyDownloader.App.MiniPlayerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Title="Spotify Downloader - Mini Player">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12,8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="48" Height="48" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Image x:Name="CoverImage" Width="48" Height="48" CornerRadius="6"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TrackTitleText" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TrackArtistText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="PlayPauseBtn" FontFamily="Segoe MDL2 Assets" Content="&#xE768;"
                        Width="36" Height="36" CornerRadius="18" Background="{ThemeResource AccentButtonBackground}"
                        BorderThickness="0" Click="OnPlayPauseClick"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="24" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border Width="200" Height="200" CornerRadius="16" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Image x:Name="LargeCoverImage" Width="200" Height="200" CornerRadius="16"/>
                </Border>

                <controls:UniformGrid x:Name="SpectrumGrid" Rows="1" Columns="32" Height="40" VerticalAlignment="Center">
                    <controls:UniformGrid.Resources>
                        <Style TargetType="Border">
                            <Setter Property="Width" Value="4"/>
                            <Setter Property="CornerRadius" Value="2,2,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Bottom"/>
                            <Setter Property="Background" Value="{ThemeResource AccentButtonBackground}"/>
                            <Setter Property="Margin" Value="1,0"/>
                        </Style>
                    </controls:UniformGrid.Resources>
                </controls:UniformGrid>

                <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Width="280" Height="4" ValueChanged="OnProgressChanged"/>
                <Grid Width="280">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PositionText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" x:Name="DurationText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                    <Button FontFamily="Segoe MDL2 Assets" Content="&#xE892;" Background="Transparent" BorderThickness="0" Width="36" Height="36" Click="OnPreviousClick"/>
                    <Button x:Name="PlayPauseLarge" FontFamily="Segoe MDL2 Assets" Content="&#xE768;"
                            Width="48" Height="48" CornerRadius="24" Background="{ThemeResource AccentButtonBackground}"
                            BorderThickness="0" Click="OnPlayPauseClick"/>
                    <Button FontFamily="Segoe MDL2 Assets" Content="&#xE893;" Background="Transparent" BorderThickness="0" Width="36" Height="36" Click="OnNextClick"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="8">
            <Button HorizontalAlignment="Center" Content="Restaurar" Style="{StaticResource SecondaryButtonStyle}" Click="OnRestoreClick"/>
        </Border>
    </Grid>
</muxc:Window>
