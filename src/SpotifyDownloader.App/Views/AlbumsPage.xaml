<Page
    x:Class="SpotifyDownloader.App.Views.AlbumsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:core="using:SpotifyDownloader.Core.Models">

    <Grid Padding="24">
        <TextBlock Text="Álbuns Salvos" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}" Margin="0,8,0,0">
            <muxc:ItemsRepeater.Layout>
                <UniformGridLayout MinItemWidth="180" MinItemHeight="240" Orientation="Horizontal"/>
            </muxc:ItemsRepeater.Layout>
            <muxc:ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="core:SpotifyAlbum">
                    <StackPanel Padding="8" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="4">
                        <Image Source="{x:Bind CoverUrl}" Width="164" Height="164" CornerRadius="8"/>
                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind Artist}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <TextBlock Text="{x:Bind AlbumTypeFormatted}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Text="{x:Bind ReleaseYear, StringFormat='• {0}'}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </muxc:ItemsRepeater.ItemTemplate>
        </muxc:ItemsRepeater>
    </Grid>
</Page>
