<Page
    x:Class="SpotifyDownloader.App.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:core="using:SpotifyDownloader.Core.Models"
    x:Name="PageRoot">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Pesquisar" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <muxc:AutoSuggestBox
                PlaceholderText="Buscar músicas, artistas, álbuns..."
                QueryIcon="Find"
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}"
                IsSuggestionListOpen="{x:Bind ViewModel.IsSuggestionsOpen, Mode=OneWay}"
                TextMemberPath="Title"
                UpdateTextOnSelect="True"
                AutoMaxDropDownHeight="True"
                SuggestionChosen="OnSuggestionChosen"
                QuerySubmitted="OnQuerySubmitted"/>

            <Button Grid.Column="1" Command="{x:Bind ViewModel.SearchOrPasteCommand}"
                    Content="Buscar" Style="{StaticResource AccentButtonStyle}" Width="100"/>
        </Grid>

        <!-- Main Results Grid -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="12">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind ViewModel.IsSearchActive, Mode=OneWay}"/>

                <GridView ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsSearchActive, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="OnTrackClick">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="core:SpotifyTrack">
                            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    Width="200" Padding="0" UseLayoutRounding="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Image Source="{x:Bind AlbumCoverUrl}" Width="200" Height="200"
                                           CornerRadius="12,12,0,0" Stretch="UniformToFill"/>

                                    <StackPanel Grid.Row="1" Margin="12,8,12,0" Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock Text="{x:Bind Artist}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,4,12,8" Spacing="8">
                                        <TextBlock Text="{x:Bind Album}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock Text="{x:Bind DurationFormatted}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Row="3" Content="Baixar"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Margin="12,0,12,12"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding ElementName=PageRoot, Path=ViewModel.DownloadTrackCommand}"
                                            CommandParameter="{x:Bind}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" ItemWidth="200"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
