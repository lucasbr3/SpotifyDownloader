<Page
    x:Class="SpotifyDownloader.App.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    x:Name="PageRoot">

    <Grid Padding="24">
        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
            <Border Width="96" Height="96" CornerRadius="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    HorizontalAlignment="Center">
                <Image Source="ms-appx:///Assets/icon.png" Width="64" Height="64" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <TextBlock Text="Spotify Downloader" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Text="Versão 1.0.0" Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>

            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    Baixe suas músicas, álbuns e playlists favoritas do Spotify.
                    Sem necessidade de autenticação. Compatível com Windows 10 e Windows 11.
                </TextBlock>
            </Border>

            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Clock" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                            <Run Text="Feito com"/> <Run Text=".NET 8" FontWeight="SemiBold"/>
                            <Run Text="e"/> <Run Text="WinUI 3" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="MusicInfo" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="YouTube + FFmpeg" Style="{StaticResource BodyTextBlockStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="World" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Português • English • Español" Style="{StaticResource BodyTextBlockStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="8">
                <Button x:Name="UpdateBtn" Content="Verificar Atualizações" HorizontalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}" Click="OnCheckUpdatesClick"/>
                <TextBlock x:Name="UpdateStatus" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>

            <TextBlock Text="© 2024 Spotify Downloader" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
