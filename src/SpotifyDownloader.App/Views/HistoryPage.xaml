<Page
    x:Class="SpotifyDownloader.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:core="using:SpotifyDownloader.Core.Models"
    x:Name="PageRoot">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Histórico" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

        <!-- Stats Bar -->
        <Grid Grid.Row="1" ColumnSpacing="16" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="Total" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.HistoryTotal, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="Sucesso" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.HistorySuccessful, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#1DB954"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="Falhas" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.HistoryFailed, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#E74C3C"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="Total Baixado" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.HistoryTotalSize, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Search -->
        <TextBox Grid.Row="2" PlaceholderText="Pesquisar no histórico..."
                 Style="{StaticResource SettingsTextBoxStyle}" Margin="0,0,0,12"
                 Text="{x:Bind ViewModel.HistorySearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextChanged="OnHistorySearchChanged"/>

        <!-- History List -->
        <ScrollViewer Grid.Row="3">
            <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.HistoryItems, Mode=OneWay}">
                <muxc:ItemsRepeater.Layout><StackLayout Orientation="Vertical"/></muxc:ItemsRepeater.Layout>
                <muxc:ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="core:DownloadItem">
                        <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                Padding="12,8" Margin="0,0,0,4">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="{x:Bind Track.AlbumCoverUrl}" Width="40" Height="40" CornerRadius="4"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Track.Title}" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Track.Artist}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{x:Bind FileSizeFormatted}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind StatusText}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind CompletedAt, StringFormat='{0:dd/MM/yy}'}" 
                                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </muxc:ItemsRepeater.ItemTemplate>
            </muxc:ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
