<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(SpotifyDownloader.Wasm.Layouts.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(SpotifyDownloader.Wasm.Layouts.MainLayout)">
            <div class="not-found">
                <h2>Página não encontrada</h2>
                <a href="/">Voltar ao início</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
